# Shared
APP_ENV=development
LOG_LEVEL=INFO

# Backend
DATABASE_URL=postgresql+asyncpg://jobfit:jobfit@localhost:5432/jobfit
SYNC_DATABASE_URL=postgresql+psycopg://jobfit:jobfit@localhost:5432/jobfit
BACKEND_CORS_ORIGINS=http://localhost:3000

# AI / LLM providers
# local  = offline heuristic fallback (default, clone-and-run)
# openai = any OpenAI-compatible Chat Completions endpoint
AI_PROVIDER=local
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_REPAIR_ATTEMPTS=2

# Embeddings
# local  = sentence-transformers with deterministic fallback
# cohere = Cohere Embed API; set COHERE_API_KEY and use embed-english-v3.0 (1024 dims)
# jina   = Jina Embeddings API; set JINA_API_KEY; recommended model jina-embeddings-v5-text-small; DB expects 384 dims
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_REQUEST_TIMEOUT_SECONDS=30
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com
JINA_API_KEY=
JINA_BASE_URL=https://api.jina.ai

# Ingestion
UPLOAD_STORAGE_DIR=storage/uploads
MAX_UPLOAD_BYTES=10000000
URL_FETCH_TIMEOUT_SECONDS=10
MAX_URL_RESPONSE_BYTES=2000000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
